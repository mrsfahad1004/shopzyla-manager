import { Globe, MapPin, Truck, DollarSign, TrendingDown, Shield, Zap, CheckCircle, AlertTriangle, Search, Settings, ArrowRight, Package, Sparkles, RefreshCw, Sliders } from 'lucide-react'
import { theme } from '../theme'

// Countries organized by region with shipping cost data
const countriesByRegion = {
  'South Asia': [
    { code: 'PK', name: 'Pakistan', flag: '🇵🇰', shippingCost: [2, 5], freeThreshold: 25, localFulfillment: true, localProviders: ['TCS', 'Leopards', 'BlueEx'] },
    { code: 'IN', name: 'India', flag: '🇮🇳', shippingCost: [5, 12], freeThreshold: 40, localFulfillment: false, localProviders: ['DTDC', 'India Post'] },
